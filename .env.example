# PS Website Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# Email Configuration (using Resend or similar)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=your-email@resend.dev
SMTP_PASS=your-resend-api-key
FROM_EMAIL=noreply@ps.io

# Contacts
CONTACT_EMAIL=team@ps.io

# App URL (for email links)
APP_URL=https://ps.io

# Analytics (optional)
ANALYTICS_KEY=your-analytics-key
SEGMENT_WRITE_KEY=your-segment-key

# Optional: Database (if using PostgreSQL for signups)
DATABASE_URL=postgresql://user:pass@localhost/ps_website

# Optional: Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL